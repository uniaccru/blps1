# Скопируйте в .env.gmail и заполните для реальной отправки на Gmail:
#   docker compose --env-file .env.gmail -f docker-compose.yml -f docker-compose.gmail.yml up --build
#
# Нужен App Password Google (не обычный пароль):
# https://myaccount.google.com/apppasswords

GMAIL_USERNAME=stolnaya.stella@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
